diff --git a/xslt3/zz_tagadapt_test.go b/xslt3/zz_tagadapt_test.go
new file mode 100644
index 0000000..529a8c8
--- /dev/null
+++ b/xslt3/zz_tagadapt_test.go
@@ -0,0 +1,22 @@
+package xslt3_test
+
+// This file adapts the harness to the helium v0.3.0 tagged release API.
+// v0.3.0 did not export helium.PermissiveFS; permissiveFS replicates its
+// behavior (an fs.FS that forwards any path verbatim to os.Open), matching
+// internal/iofs.PermissiveRoot which helium.PermissiveFS returns in later
+// releases. This is real old behavior, not a degrade-stub.
+
+import (
+	"io/fs"
+	"os"
+)
+
+type permissiveRootFS struct{}
+
+func (permissiveRootFS) Open(name string) (fs.File, error) {
+	return os.Open(name) //nolint:gosec // intentional passthrough, mirrors iofs.PermissiveRoot
+}
+
+func permissiveFS() fs.FS {
+	return permissiveRootFS{}
+}
